# Azure Bot Registration (SingleTenant)
MICROSOFT_APP_ID=<your-app-id>
MICROSOFT_APP_PASSWORD=<your-app-password>
MICROSOFT_APP_TENANT_ID=<your-tenant-id>

# API Server
PORT=3978
# Bearer key required by POST /api/send (header: x-api-key)
# Deixe vazio em dev local para desabilitar (NÃO recomendado em produção)
API_KEY=<choose-a-strong-random-string>
# Concorrência de envio de batches Service Bus durante o fan-out (default 5)
SEND_FLUSH_CONCURRENCY=5

# Azure Service Bus (fan-out das mensagens)
SERVICE_BUS_CONNECTION=<your-service-bus-connection-string>
QUEUE_NAME=send-messages

# Azure Table Storage (durabilidade das conversationReferences)
STORAGE_CONNECTION=<your-storage-connection-string>

# Azure Cache for Redis (job counters + refs index + token bucket + msg cache)
# Formato Azure: <host>:6380,password=<key>,ssl=True
# Formato genérico: rediss://:<password>@<host>:6380
REDIS_CONNECTION=<your-redis-connection-string>

# Worker tuning
MAX_CONCURRENT=10

# Token bucket global (limite de envio agregado p/ Bot Framework)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_SEC=50
RATE_LIMIT_CAPACITY=50
# RATE_LIMIT_KEY=ratelimit:bot   # opcional, namespace customizado

